/*---\ncompatibilityVersion: naiscript-1.0\nid: b3b287e5-af9c-4874-a88d-27f3dec9e8d8\nname: ATTG UI\ncreatedAt: 1775059445606\nupdatedAt: 1775076462704\nversion: 1.7.6\nauthor: Spudz Pasta\nmemoryLimit: 8\n---*/\n// ======================================================\n//  SCRIPT PANEL — ATTG WITH RANDOMIZER\n// ======================================================\n\nlet authorInput = "";\nlet titleInput = "";\nlet tagsInput = "";\nlet genreInput = "";\nlet sValueInput = "4";\nlet styleInput = "";\n\nlet storyPerms = await api.v1.permissions.request('storyEdit');\n\nif (storyPerms) {\n  api.v1.log('Permission granted!');\n} else {\n  api.v1.log('Permission denied');\n  api.v1.ui.toast('Awaiting your orders, boss.', { type: 'error' });\n}\n\n// Randomizer pools\nconst RANDOM_AUTHORS = [\n    "Elara Ozonium", "Brian Lumley", "Vera Straylight",\n    "Someone uniquely him", "A homeless guy", "Mira Kess"\n];\n\nconst RANDOM_TITLES = [\n    "The Soonening", "Ashfall Meridian", "No, It never was",\n    "Starless Vector", "The Last Quiet Orbit", "Hollow Sun, Burning Sky",\n    "But how many are left?"\n];\n\nconst RANDOM_TAGS = [\n    "epic, grand, fluffy, sfw",\n    "grimdark, cosmic, hard science",\n    "romantic, soft, character-driven",\n    "mystical, surreal, dreamlike",\n    "action-heavy, pulpy, fast-paced",\n    "epic, sweeping, mythic",\n    "grand, operatic, world-shaking",\n    "heroic, legendary, fate-driven",\n    "cosmic, vast, awe-filled",\n    "high stakes, destiny-bound, monumental",\n    "grimdark, brutal, unforgiving",\n    "gritty, grounded, bleak",\n    "harsh, violent, morally gray",\n    "cosmic horror, existential dread",\n    "decay, entropy, ruin",\n    "surreal, dreamlike, uncanny",\n    "weirdcore, liminal, off-kilter",\n    "psychedelic, kaleidoscopic, bizarre",\n    "metafictional, self-aware, experimental",\n    "absurdist, chaotic, unpredictable",\n    "soft, warm, gentle",\n    "cozy, comforting, slice-of-life",\n    "wholesome, fluffy, heartwarming",\n    "quiet, reflective, peaceful",\n    "domestic, tender, low-stakes",\n    "romantic, yearning, intimate",\n    "slow-burn, emotional, character-driven",\n    "passionate, dramatic, tangled",\n    "bittersweet, tender, vulnerable",\n    "messy, human, heartfelt",\n    "mystical, arcane, enchanted",\n    "ritualistic, symbolic, mythic",\n    "folkloric, ancient, uncanny",\n    "ethereal, luminous, otherworldly",\n    "occult, esoteric, forbidden"\n];\n\nconst RANDOM_GENRES = [\n    "scifi, space opera",\n    "fantasy, mythic",\n    "horror, cosmic",\n    "romance, slice of life",\n    "thriller, techno",\n    "cyberpunk, post-cyberpunk",\n    "biopunk, genepunk",\n    "solarpunk, lunarpunk",\n    "post-apocalyptic, wasteland",\n    "first contact, alien cultures",\n    "time travel, paradox fiction",\n    "high fantasy, mythic",\n    "low fantasy, grounded",\n    "urban fantasy, modern magic",\n    "dark fantasy, occult",\n    "fairytale, folkloric",\n    "sword and sorcery",\n    "portal fantasy, isekai",\n    "cosmic horror, unknowable",\n    "psychological horror",\n    "body horror, grotesque",\n    "supernatural horror",\n    "folk horror, ritualistic",\n    "techno-horror, AI dread"\n];\n\nconst RANDOM_SVALUES = ["2", "3", "4", "5"];\n\napi.v1.ui.register([\n    {\n        type: "scriptPanel",\n        name: "ATTG stuff",\n        content: [\n            { type: "text", text: "Tell me your story, boss:" },\n\n            // ---- Author ----\n            {\n                type: "textInput",\n                label: "Author",\n                placeholder: "e.g., Elara Ozonium",\n                onChange: (value) => { authorInput = value.trim(); }\n            },\n\n            // ---- Title ----\n            {\n                type: "textInput",\n                label: "Title",\n                placeholder: "e.g., The Soonening",\n                onChange: (value) => { titleInput = value.trim(); }\n            },\n\n            // ---- Tags ----\n            {\n                type: "textInput",\n                label: "Tags (comma-separated)",\n                placeholder: "e.g., epic, grand, fluffy, sfw",\n                onChange: (value) => { tagsInput = value.trim(); }\n            },\n\n            // ---- Genre ----\n            {\n                type: "textInput",\n                label: "Genre (comma-separated)",\n                placeholder: "e.g., scifi, space opera",\n                onChange: (value) => { genreInput = value.trim(); }\n            },\n\n            // ---- S-Value ----\n            {\n                type: "textInput",\n                label: "S-Value",\n                placeholder: "Default: 4",\n                onChange: (value) => { sValueInput = value.trim() || "4"; }\n            },\n\n            // ---- Manual Style Input ----\n            {\n                type: "textInput",\n                label: "Style (optional), not recommended here.",\n                placeholder: "e.g., vivid, detailed",\n            },\n\n            //- Buttons\n            {\n                type: "button",\n                text: "Set ATTG",\n                callback: async () => {\n\n                    let block =\n                        `[ Author: ${authorInput}; ` +\n                        `Title: ${titleInput}; ` +\n                        `Tags: ${tagsInput}; ` +\n                        `Genre: ${genreInput} ][ S: ${sValueInput} ]`;\n\n                    if (styleInput !== "") {\n                        block += `\n[ Style: ${styleInput} ]`;\n                    }\n\n                    await api.v1.memory.set(block);\n                    await api.v1.story.title.set(titleInput);\n                    api.v1.log("Hooked you up:");\n                    api.v1.log(block);\n                }\n            },\n            {\n                type: "button",\n                text: "Just THROW me",\n                callback: async () => {\n                    authorInput = RANDOM_AUTHORS[Math.floor(Math.random() * RANDOM_AUTHORS.length)];\n                    titleInput = RANDOM_TITLES[Math.floor(Math.random() * RANDOM_TITLES.length)];\n                    tagsInput = RANDOM_TAGS[Math.floor(Math.random() * RANDOM_TAGS.length)];\n                    genreInput = RANDOM_GENRES[Math.floor(Math.random() * RANDOM_GENRES.length)];\n                    sValueInput = RANDOM_SVALUES[Math.floor(Math.random() * RANDOM_SVALUES.length)];\n\n                    api.v1.log("Here's an adventure, boss:");\n                    api.v1.log(`${authorInput}, ${titleInput}, ${tagsInput}, ${genreInput}, S=${sValueInput}, Style=${styleInput}`);\n                }\n            },\n                // ---- Save Settings ----\n                {\n                    type: "button",\n                    text: "Save Settings",\n                    callback: async () => {\n                        const settings = {\n                            authorInput,\n                            titleInput,\n                            tagsInput,\n                            genreInput,\n                            sValueInput,\n                            styleInput\n                        };\n\n                        await api.v1.storage.set("attg-settings", settings);\n                        api.v1.log("Settings saved.");\n                    }\n                },\n\n                // ---- Load Settings ----\n                {\n                    type: "button",\n                    text: "Load Settings",\n                    callback: async () => {\n                        const settings = await api.v1.storage.get("attg-settings");\n\n                        if (!settings) {\n                            api.v1.log("No saved settings found.");\n                            return;\n                        }\n\n                        authorInput = settings.authorInput || "";\n                        titleInput = settings.titleInput || "";\n                        tagsInput = settings.tagsInput || "";\n                        genreInput = settings.genreInput || "";\nsValueInput = settings.sValueInput || "4";\n                        styleInput = settings.styleInput || "";\n\n                        api.v1.log("Settings loaded.");\n                    }\n                },\n\n                // ---- Export Settings ----\n                {\n                    type: "button",\n                    text: "Export Settings",\n                    callback: async () => {\n                        const settings = {\n                            authorInput,\n                            titleInput,\n                            tagsInput,\n                            genreInput,\n                            sValueInput,\n                            styleInput\n                        };\n\n                        const json = JSON.stringify(settings, null, 2);\n                        api.v1.log("Exported Settings:\n" + json);\n                    }\n                },\n\n        ]\n    }\n]);